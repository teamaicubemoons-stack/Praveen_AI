//@version=6
strategy(
     title             = "EMA Pro Strategy - RSI + Volume + ATR (FIXED)",
     shorttitle        = "EMA Pro Fixed",
     overlay           = true,
     initial_capital   = 10000,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.1,
     slippage          = 2
 )

// ══════════════════════════════════════════════════════
//  BACKTEST DATE FILTER
// ══════════════════════════════════════════════════════

grp0 = "Backtest Date Range"
startDate = input.time(timestamp("01 Jan 2020 00:00"), "Start Date", group=grp0)
endDate   = input.time(timestamp("31 Dec 2030 00:00"), "End Date",   group=grp0)
inRange   = time >= startDate and time <= endDate

// ══════════════════════════════════════════════════════
//  INPUTS
// ══════════════════════════════════════════════════════

grp1 = "EMA Settings"
fastLen  = input.int(21,  "Fast EMA",  minval=1, group=grp1)
slowLen  = input.int(50,  "Slow EMA",  minval=1, group=grp1)
trendLen = input.int(200, "Trend EMA", minval=1, group=grp1)
src      = input.source(close, "Source", group=grp1)

grp2 = "RSI Filter"
useRSI  = input.bool(true, "Enable RSI Filter", group=grp2)
rsiLen  = input.int(14, "RSI Length",  minval=1,            group=grp2)
rsiBull = input.int(50, "RSI Long >",  minval=1, maxval=99, group=grp2) // Lowered from 55
rsiBear = input.int(50, "RSI Short <", minval=1, maxval=99, group=grp2) // Raised from 45

grp3 = "Volume Filter"
useVol  = input.bool(true,  "Enable Volume Filter", group=grp3)
volMult = input.float(1.1,  "Volume > N x Avg", minval=0.5, step=0.1, group=grp3) // Lowered from 1.2
volLen  = input.int(20,     "Volume MA Length",  minval=1,   group=grp3)

grp4 = "Risk Management"
useATR   = input.bool(true,  "ATR-Based SL/TP",  group=grp4)
atrLen   = input.int(14,     "ATR Length",    minval=1,            group=grp4)
atrSLMul = input.float(1.5,  "SL = N x ATR",  minval=0.5, step=0.1, group=grp4)
atrTPMul = input.float(3.0,  "TP = N x ATR",  minval=0.5, step=0.1, group=grp4)
useTrail = input.bool(true,  "Trailing Stop", group=grp4)
trailMul = input.float(2.0,  "Trail = N x ATR", minval=0.5, step=0.1, group=grp4)

grp5 = "Trade Direction"
tradeDir = input.string("Both", "Direction",
             options=["Long Only", "Short Only", "Both"], group=grp5)

grp6 = "Session Filter"
useBar = input.bool(true, "Avoid Monday Open (4h)", group=grp6)

// ══════════════════════════════════════════════════════
//  CALCULATIONS
// ══════════════════════════════════════════════════════

fastEMA  = ta.ema(src, fastLen)
slowEMA  = ta.ema(src, slowLen)
trendEMA = ta.ema(src, trendLen)

rsiVal  = ta.rsi(close, rsiLen)
atrVal  = ta.atr(atrLen)
volAvg  = ta.sma(volume, volLen)

crossUp = ta.crossover(fastEMA, slowEMA)
crossDn = ta.crossunder(fastEMA, slowEMA)

aboveTrend = close > trendEMA
belowTrend = close < trendEMA

rsiLong  = not useRSI or (rsiVal > rsiBull) // Removed upper cap of 80
rsiShort = not useRSI or (rsiVal < rsiBear) // Removed lower cap of 20

volOK = not useVol or (volume > volAvg * volMult)
// Avoid only first 4 hours of Monday
isMondayOpen = dayofweek == dayofweek.monday and hour < 4
dayOK = not useBar or not isMondayOpen

longOK  = tradeDir == "Long Only"  or tradeDir == "Both"
shortOK = tradeDir == "Short Only" or tradeDir == "Both"

enterLong  = inRange and crossUp and aboveTrend and rsiLong  and volOK and dayOK and longOK
enterShort = inRange and crossDn and belowTrend and rsiShort and volOK and dayOK and shortOK

// ══════════════════════════════════════════════════════
//  STRATEGY EXECUTION (FIXED SL/TP LOCKING)
// ══════════════════════════════════════════════════════

var float slLevel = na
var float tpLevel = na
var float trailDist = na

if enterLong
    strategy.entry("Long", strategy.long, comment="BUY")
    slLevel := close - (atrVal * atrSLMul)
    tpLevel := close + (atrVal * atrTPMul)
    trailDist := (atrVal * trailMul)

if enterShort
    strategy.entry("Short", strategy.short, comment="SELL")
    slLevel := close + (atrVal * atrSLMul)
    tpLevel := close - (atrVal * atrTPMul)
    trailDist := (atrVal * trailMul)

// Reset levels when no position
if strategy.position_size == 0
    slLevel := na
    tpLevel := na
    trailDist := na

// Close all trades after end date
if time > endDate and strategy.position_size != 0
    strategy.close_all(comment="Date End")

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long",
         stop         = useATR   ? slLevel : na,
         limit        = useATR   ? tpLevel : na,
         trail_points = useTrail ? trailDist / syminfo.mintick : na,
         comment_loss = "SL", comment_profit = "TP")

if strategy.position_size < 0
    strategy.exit("Short Exit", "Short",
         stop         = useATR   ? slLevel : na,
         limit        = useATR   ? tpLevel : na,
         trail_points = useTrail ? trailDist / syminfo.mintick : na,
         comment_loss = "SL", comment_profit = "TP")

// ══════════════════════════════════════════════════════
//  VISUALS
// ══════════════════════════════════════════════════════

col_fast = fastEMA > slowEMA ? color.new(#00e5ff, 0) : color.new(#ff6b6b, 0)

p1 = plot(fastEMA, "Fast EMA", color=col_fast, linewidth=2)
p2 = plot(slowEMA, "Slow EMA", color=color.new(#ffa726, 0), linewidth=2)
plot(trendEMA, "Trend EMA", color=color.new(color.gray, 40), linewidth=1, style=plot.style_circles)

fill(p1, p2, color=fastEMA > slowEMA ? color.new(#00e5ff, 88) : color.new(#ff6b6b, 88))

bgcolor(inRange ? color.new(color.blue, 97) : na, title="Backtest Range")

plotshape(enterLong,  "Long Signal",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.normal)
plotshape(enterShort, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.normal)

// Visual SL/TP lines
plot(strategy.position_size != 0 ? slLevel : na, "Stop Loss", color=color.new(color.red, 40), style=plot.style_linebr, linewidth=1)
plot(strategy.position_size != 0 ? tpLevel : na, "Take Profit", color=color.new(color.lime, 40), style=plot.style_linebr, linewidth=1)

// RSI
plot(rsiVal, "RSI", color=color.new(color.purple, 0), display=display.pane)
hline(rsiBull, "RSI Long Threshold",  color=color.new(color.lime, 50), linestyle=hline.style_dashed)
hline(rsiBear, "RSI Short Threshold", color=color.new(color.red,  50), linestyle=hline.style_dashed)

// INFO TABLE
var table t = table.new(position.top_right, 2, 10, bgcolor=color.new(#0d1117, 80), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    rrRatio = atrTPMul / atrSLMul
    table.cell(t, 0, 0, "System Status", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 0, "FIXED & ACTIVE", text_color=color.lime, text_size=size.small)
    table.cell(t, 0, 1, "Net Profit", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 1, "$" + str.tostring(math.round(strategy.netprofit, 2)), text_color=strategy.netprofit >= 0 ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 2, "Trades", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(strategy.closedtrades), text_color=color.white, text_size=size.small)
