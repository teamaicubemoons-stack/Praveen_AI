//@version=6
strategy(
 title="EMA Pro Ultimate Hybrid V13",
 shorttitle="EMA V13",
 overlay=true,
 initial_capital=10000,
 default_qty_type=strategy.cash,
 commission_type=strategy.commission.percent,
 commission_value=0.1,
 slippage=2
)

//════════════════════════════
// SETTINGS
//════════════════════════════

grp0="Range & Risk"
lookYears  = input.int(10,"Lookback Years",minval=1,group=grp0)
riskPerTrd = input.float(1.5,"Risk Per Trade %",step=0.1,group=grp0)

grp1="EMA Settings"
fastLen = input.int(9,"Fast EMA",group=grp1)
slowLen = input.int(21,"Slow EMA",group=grp1)
trendLen= input.int(200,"Trend EMA",group=grp1)

usePB = input.bool(true,"Pullback Entries",group=grp1)
useTrendFilter = input.bool(true,"Use Trend Filter",group=grp1)

grp2="Filters"
useADX = input.bool(true,"ADX Filter",group=grp2)
adxMin = input.int(20,"Minimum ADX",group=grp2)

grp3="Exits"
atrSLMul  = input.float(1.5,"SL ATR x",group=grp3)
atrTP1Mul = input.float(1.5,"TP1 ATR x",group=grp3)
atrTP2Mul = input.float(3.5,"TP2 ATR x",group=grp3)
moveBE    = input.bool(true,"Move SL To BreakEven",group=grp3)


//════════════════════════════
// CALCULATIONS
//════════════════════════════

autoStart = timenow - (lookYears * 31536000000)
inRange = time >= autoStart

fastEMA  = ta.ema(close,fastLen)
slowEMA  = ta.ema(close,slowLen)
trendEMA = ta.ema(close,trendLen)

atrVal = ta.atr(14)
rsiVal = ta.rsi(close,14)
[plusDI, minusDI, adxVal] = ta.dmi(14,14)

weekly200 = request.security(syminfo.tickerid,"W",ta.ema(close,200))

crossUp = ta.crossover(fastEMA,slowEMA)
crossDn = ta.crossunder(fastEMA,slowEMA)

pbLong = low<=fastEMA
pbShort= high>=fastEMA

trendLongOK  = not useTrendFilter or close>trendEMA
trendShortOK = not useTrendFilter or close<trendEMA

adxOK = not useADX or adxVal>adxMin

// Relaxed RSI for more trades
rsiLongOK = rsiVal>40
rsiShortOK= rsiVal<60

longSignal=
 inRange and
 (usePB ? (close>fastEMA and pbLong) : crossUp) and
 trendLongOK and
 adxOK and
 rsiLongOK

shortSignal=
 inRange and
 (usePB ? (close<fastEMA and pbShort) : crossDn) and
 trendShortOK and
 adxOK and
 rsiShortOK


//════════════════════════════
// POSITION SIZING
//════════════════════════════

slDist = atrVal*atrSLMul

riskAmount = strategy.equity*(riskPerTrd/100)

posQty = riskAmount/slDist

var float entryPx = na
var float dynamicSL = na
var float entryATR = na


//════════════════════════════
// EXECUTION
//════════════════════════════

if longSignal and strategy.position_size<=0
    strategy.entry("Long",strategy.long,qty=posQty)
    
if shortSignal and strategy.position_size>=0
    strategy.entry("Short",strategy.short,qty=posQty)


// lock real fill price + ATR after entry
if strategy.position_size!=0 and na(entryPx)
    entryPx:=strategy.position_avg_price
    entryATR:=atrVal

if strategy.position_size>0 and na(dynamicSL)
    dynamicSL:=entryPx-(entryATR*atrSLMul)

if strategy.position_size<0 and na(dynamicSL)
    dynamicSL:=entryPx+(entryATR*atrSLMul)


// BreakEven Logic
if strategy.position_size>0 and moveBE and high>=entryPx+(entryATR*atrTP1Mul)
    dynamicSL:=entryPx

if strategy.position_size<0 and moveBE and low<=entryPx-(entryATR*atrTP1Mul)
    dynamicSL:=entryPx


//════════════════════════════
// EXITS
//════════════════════════════

if strategy.position_size!=0

    tp1=
      strategy.position_size>0 ?
      entryPx+(entryATR*atrTP1Mul):
      entryPx-(entryATR*atrTP1Mul)

    tp2=
      strategy.position_size>0 ?
      entryPx+(entryATR*atrTP2Mul):
      entryPx-(entryATR*atrTP2Mul)

    strategy.exit(
      "Partial Exit",
      qty_percent=50,
      limit=tp1
     )

    strategy.exit(
      "Final Exit",
      stop=dynamicSL,
      limit=tp2
     )

if strategy.position_size==0
    entryPx:=na
    dynamicSL:=na
    entryATR:=na


//════════════════════════════
// VISUALS
//════════════════════════════

fColor=close>fastEMA ? color.aqua : color.red
sColor=close>slowEMA ? color.orange : color.maroon

plot(fastEMA,color=fColor,linewidth=2,title="Fast EMA")
plot(slowEMA,color=sColor,linewidth=2,title="Slow EMA")

plot(
 trendEMA,
 color=color.new(color.white,70),
 linewidth=1,
 title="Trend EMA"
)

plot(
 weekly200,
 color=color.new(color.yellow,80),
 linewidth=1,
 style=plot.style_linebr,
 title="Weekly 200 EMA"
)

bgcolor(
 strategy.position_size>0?
 color.new(color.green,92):
 strategy.position_size<0?
 color.new(color.red,92):
 na
)

plotshape(
 longSignal,
 title="BUY",
 style=shape.triangleup,
 location=location.belowbar,
 color=color.lime,
 size=size.small
)

plotshape(
 shortSignal,
 title="SELL",
 style=shape.triangledown,
 location=location.abovebar,
 color=color.red,
 size=size.small
)


//════════════════════════════
// DASHBOARD
//════════════════════════════

var table tb=
 table.new(
 position.top_right,
 2,
 6,
 bgcolor=color.new(#0d1117,85)
 )

if barstate.islast

    winR=
     strategy.wintrades/
     math.max(strategy.closedtrades,1)*100

    table.cell(tb,0,0,"EMA V13 PRO",text_color=color.white)
    table.cell(tb,1,0,"ACTIVE",text_color=color.lime)

    table.cell(tb,0,1,"Win Rate")
    table.cell(tb,1,1,str.tostring(math.round(winR,2))+"%")

    table.cell(tb,0,2,"Trades")
    table.cell(tb,1,2,str.tostring(strategy.closedtrades))

    table.cell(tb,0,3,"Net Profit")
    table.cell(tb,1,3,"$"+str.tostring(math.round(strategy.netprofit,2)))

    table.cell(tb,0,4,"Max DD")
    table.cell(
     tb,1,4,
     str.tostring(
      math.round(
       strategy.max_drawdown/
       strategy.initial_capital*100,
       2
      )
     )+"%"
    )

    pf=
      strategy.grossloss!=0 ?
      strategy.grossprofit/math.abs(strategy.grossloss)
      :0

    table.cell(tb,0,5,"Profit Factor")
    table.cell(tb,1,5,str.tostring(math.round(pf,2)))