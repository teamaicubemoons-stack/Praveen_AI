//@version=6
strategy(
     title             = "EMA Pro - Ultimate Hybrid V12 (Final Polish)",
     shorttitle        = "EMA V12",
     overlay           = true,
     initial_capital   = 10000,
     default_qty_type  = strategy.cash,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.1,
     slippage          = 2
 )

// ══════════════════════════════════════════════════════
//  SETTINGS
// ══════════════════════════════════════════════════════

grp0 = "Range & Risk"
useAuto    = input.bool(true, "Use Auto Lookback", group=grp0)
lookYears  = input.int(2, "Lookback Years", minval=1, group=grp0)
riskPerTrd = input.float(1.5, "Risk Per Trade (%)", minval=0.1, step=0.1, group=grp0)

grp1 = "EMA Settings"
fastLen  = input.int(21,  "Fast EMA", group=grp1)
slowLen  = input.int(50,  "Slow EMA", group=grp1)
trendLen = input.int(200, "Trend EMA", group=grp1)
usePB    = input.bool(false, "Enable Pullback Entry Mode", group=grp1)

grp2 = "Exits"
atrSLMul   = input.float(1.5, "Initial SL ATR x", group=grp2)
atrTP1Mul  = input.float(1.5, "Partial TP ATR x", group=grp2)
atrTP2Mul  = input.float(3.5, "Final TP ATR x", group=grp2)
moveBE     = input.bool(true, "Move SL to BE after Partial", group=grp2)

// ══════════════════════════════════════════════════════
//  CALCULATIONS
// ══════════════════════════════════════════════════════

autoStart = timenow - (lookYears * 31536000000)
inRange = time >= autoStart

fastEMA  = ta.ema(close, fastLen)
slowEMA  = ta.ema(close, slowLen)
trendEMA = ta.ema(close, trendLen)
atrVal   = ta.atr(14)
rsiVal   = ta.rsi(close, 14)

// Weekly Trend (Visual Only)
weekly200 = request.security(syminfo.tickerid, "W", ta.ema(close, 200))

// Signals
crossUp = ta.crossover(fastEMA, slowEMA)
crossDn = ta.crossunder(fastEMA, slowEMA)

pbOKLong  = not usePB or low <= fastEMA
pbOKShort = not usePB or high >= fastEMA

longSignal  = inRange and (usePB ? (close > fastEMA and pbOKLong) : crossUp) and close > trendEMA and rsiVal > 45
shortSignal = inRange and (usePB ? (close < fastEMA and pbOKShort) : crossDn) and close < trendEMA and rsiVal < 55

// ══════════════════════════════════════════════════════
//  EXECUTION
// ══════════════════════════════════════════════════════

float slDist     = atrVal * atrSLMul
float riskAmount = strategy.equity * (riskPerTrd / 100)
float posQty     = riskAmount / slDist

var float entryPx = na
var float dynamicSL = na

if longSignal
    strategy.entry("Long", strategy.long, qty=posQty, comment="BUY")
    entryPx := close
    dynamicSL := close - slDist

if shortSignal
    strategy.entry("Short", strategy.short, qty=posQty, comment="SELL")
    entryPx := close
    dynamicSL := close + slDist

// BE Logic
if strategy.position_size > 0 and moveBE and high >= (entryPx + (atrVal * atrTP1Mul))
    dynamicSL := entryPx
if strategy.position_size < 0 and moveBE and low <= (entryPx - (atrVal * atrTP1Mul))
    dynamicSL := entryPx

// Exits
if strategy.position_size != 0
    strategy.exit("P-Exit", qty_percent=50, limit=strategy.position_size > 0 ? entryPx + (atrVal * atrTP1Mul) : entryPx - (atrVal * atrTP1Mul), comment="TP1")
    strategy.exit("F-Exit", stop=dynamicSL, limit=strategy.position_size > 0 ? entryPx + (atrVal * atrTP2Mul) : entryPx - (atrVal * atrTP2Mul), comment="TP2/SL")

if strategy.position_size == 0
    entryPx := na, dynamicSL := na

// ══════════════════════════════════════════════════════
//  VISUALS (V12 ELITE)
// ══════════════════════════════════════════════════════

// EMA Colors
fColor = close > fastEMA ? color.aqua : color.red
sColor = close > slowEMA ? color.orange : color.maroon
plot(fastEMA, color=fColor, linewidth=2, title="Fast EMA")
plot(slowEMA, color=sColor, linewidth=2, title="Slow EMA")
plot(trendEMA, color=color.new(color.white, 70), linewidth=1, title="Trend EMA")
plot(weekly200, color=color.new(color.yellow, 80), style=plot.style_linebr, linewidth=1, title="Weekly 200 EMA")

// BG Highlights
bgcolor(strategy.position_size > 0 ? color.new(color.green, 92) : strategy.position_size < 0 ? color.new(color.red, 92) : na)

// Signals Labels
plotshape(longSignal, "BUY", shape.triangleup, location.belowbar, color.lime, size=size.small, text="BUY", textcolor=color.lime)
plotshape(shortSignal, "SELL", shape.triangledown, location.abovebar, color.red, size=size.small, text="SELL", textcolor=color.red)

// Dashboard (Enhanced)
var table tb = table.new(position.top_right, 2, 5, bgcolor=color.new(#0d1117, 85), border_width=1, border_color=color.gray)
if barstate.islast
    winR = strategy.wintrades / math.max(1, strategy.closedtrades) * 100
    table.cell(tb, 0, 0, "EMA V12 PRO", text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 0, "ACTIVE", text_color=color.lime, text_size=size.small)
    table.cell(tb, 0, 1, "Net Profit", text_color=color.silver)
    table.cell(tb, 1, 1, "$" + str.tostring(math.round(strategy.netprofit, 2)), text_color=color.lime)
    table.cell(tb, 0, 2, "Win Rate", text_color=color.silver)
    table.cell(tb, 1, 2, str.tostring(math.round(winR, 2)) + "%", text_color=color.aqua)
    table.cell(tb, 0, 3, "Max DD", text_color=color.silver)
    table.cell(tb, 1, 3, str.tostring(math.round(strategy.max_drawdown / strategy.initial_capital * 100, 2)) + "%", text_color=color.orange)
    table.cell(tb, 0, 4, "Total Trades", text_color=color.silver)
    table.cell(tb, 1, 4, str.tostring(strategy.closedtrades), text_color=color.white)
