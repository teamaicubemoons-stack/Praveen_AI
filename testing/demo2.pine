//@version=6
strategy(
     title             = "EMA Pro - Ultimate Hybrid V11",
     shorttitle        = "EMA V11",
     overlay           = true,
     initial_capital   = 10000,
     default_qty_type  = strategy.cash,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.1,
     slippage          = 2
 )

// ══════════════════════════════════════════════════════
//  SETTINGS
// ══════════════════════════════════════════════════════

grp0 = "Range & Risk"
useAuto    = input.bool(true, "Use Auto Lookback", group=grp0)
lookYears  = input.int(2, "Lookback Years", minval=1, group=grp0)
riskPerTrd = input.float(1.5, "Risk Per Trade (%)", minval=0.1, step=0.1, group=grp0)

grp1 = "EMA Settings"
fastLen  = input.int(21,  "Fast EMA", group=grp1)
slowLen  = input.int(50,  "Slow EMA", group=grp1)
trendLen = input.int(200, "Trend EMA", group=grp1)
usePB    = input.bool(false, "Enable Pullback Entry (More Accurate, Less Trades)", group=grp1)

grp2 = "Exits"
atrSLMul   = input.float(1.5, "Initial SL ATR x", group=grp2)
atrTP1Mul  = input.float(1.5, "Partial TP ATR x", group=grp2)
atrTP2Mul  = input.float(3.5, "Final TP ATR x", group=grp2)
moveBE     = input.bool(true, "Move SL to BE after Partial", group=grp2)

// ══════════════════════════════════════════════════════
//  CALCULATIONS
// ══════════════════════════════════════════════════════

autoStart = timenow - (lookYears * 31536000000)
inRange = time >= autoStart

fastEMA  = ta.ema(close, fastLen)
slowEMA  = ta.ema(close, slowLen)
trendEMA = ta.ema(close, trendLen)
atrVal   = ta.atr(14)
rsiVal   = ta.rsi(close, 14)

// Signals
crossUp = ta.crossover(fastEMA, slowEMA)
crossDn = ta.crossunder(fastEMA, slowEMA)

pbOKLong  = not usePB or low <= fastEMA
pbOKShort = not usePB or high >= fastEMA

longSignal  = inRange and (usePB ? (close > fastEMA and pbOKLong) : crossUp) and close > trendEMA and rsiVal > 45
shortSignal = inRange and (usePB ? (close < fastEMA and pbOKShort) : crossDn) and close < trendEMA and rsiVal < 55

// ══════════════════════════════════════════════════════
//  RISK & POSITION SIZING
// ══════════════════════════════════════════════════════

float slDist     = atrVal * atrSLMul
float riskAmount = strategy.equity * (riskPerTrd / 100)
float posQty     = riskAmount / slDist

var float entryPx = na
var float dynamicSL = na

if longSignal
    strategy.entry("Long", strategy.long, qty=posQty, comment="BUY")
    entryPx := close
    dynamicSL := close - slDist

if shortSignal
    strategy.entry("Short", strategy.short, qty=posQty, comment="SELL")
    entryPx := close
    dynamicSL := close + slDist

// Guardian Logic (Break-Even)
if strategy.position_size > 0 and moveBE
    if high >= (entryPx + (atrVal * atrTP1Mul))
        dynamicSL := entryPx

if strategy.position_size < 0 and moveBE
    if low <= (entryPx - (atrVal * atrTP1Mul))
        dynamicSL := entryPx

// Exits
if strategy.position_size != 0
    strategy.exit("P-Exit", qty_percent=50, limit=strategy.position_size > 0 ? entryPx + (atrVal * atrTP1Mul) : entryPx - (atrVal * atrTP1Mul), comment="TP1")
    strategy.exit("F-Exit", stop=dynamicSL, limit=strategy.position_size > 0 ? entryPx + (atrVal * atrTP2Mul) : entryPx - (atrVal * atrTP2Mul), comment="TP2/SL")

if strategy.position_size == 0
    entryPx := na, dynamicSL := na

// ══════════════════════════════════════════════════════
//  VISUALS
// ══════════════════════════════════════════════════════

plot(fastEMA, color=#00e5ff, linewidth=2)
plot(slowEMA, color=#ff9100, linewidth=2)
plot(trendEMA, color=color.new(color.white, 70))

var table tb = table.new(position.top_right, 2, 4, bgcolor=color.new(#0d1117, 80), border_width=1)
if barstate.islast
    table.cell(tb, 0, 0, "Profit", text_color=color.silver)
    table.cell(tb, 1, 0, "$" + str.tostring(math.round(strategy.netprofit, 2)), text_color=color.lime)
    table.cell(tb, 0, 1, "Win Rate", text_color=color.silver)
    table.cell(tb, 1, 1, str.tostring(math.round(strategy.wintrades / math.max(1, strategy.closedtrades) * 100, 2)) + "%", text_color=color.aqua)
    table.cell(tb, 0, 2, "Drawdown", text_color=color.silver)
    table.cell(tb, 1, 2, str.tostring(math.round(strategy.max_drawdown / strategy.initial_capital * 100, 2)) + "%", text_color=color.orange)
    table.cell(tb, 0, 3, "Trades", text_color=color.silver)
    table.cell(tb, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white)
